{
	"name": "plebeian.market",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"main": "src/index.tsx",
	"module": "src/index.tsx",
	"scripts": {
		"generate-routes": "tsr generate",
		"watch-routes": "tsr watch",
		"dev": "bun --hot src/index.tsx --host 0.0.0.0",
		"dev:local-only": "LOCAL_RELAY_ONLY=true bun --hot src/index.tsx --host 0.0.0.0",
		"dev:seed": "bun run startup && bun run seed && bun --hot src/index.tsx --host 0.0.0.0",
		"start": "NODE_ENV=production bun run generate-routes && bun src/index.tsx",
		"start:local-only": "NODE_ENV=production LOCAL_RELAY_ONLY=true bun run generate-routes && bun src/index.tsx",
		"start:production": "NODE_ENV=production bun src/index.tsx",
		"start:staging": "NODE_ENV=production bun src/index.tsx",
		"build": "bun run generate-routes && bun run build.ts",
		"build:production": "NODE_ENV=production bun run generate-routes && bun run build.ts --minify --source-map=none",
		"deploy:staging": "bash scripts/deploy-staging.sh",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"seed": "bun run scripts/seed.ts",
		"startup": "bun run scripts/startup.ts",
		"build-icons": "bun run scripts/build-icons.ts",
		"test:e2e": "NODE_OPTIONS='--dns-result-order=ipv4first' playwright test --config=e2e/playwright.config.ts",
		"test:e2e:headed": "NODE_OPTIONS='--dns-result-order=ipv4first' playwright test --config=e2e/playwright.config.ts --headed",
		"test:e2e:ui": "NODE_OPTIONS='--dns-result-order=ipv4first' playwright test --config=e2e/playwright.config.ts --ui",
		"test:e2e:debug": "NODE_OPTIONS='--dns-result-order=ipv4first' playwright test --config=e2e/playwright.config.ts --debug",
		"dev:contextvm-server": "bun run contextvm/server.ts",
		"test:unit": "bun test $(find contextvm src -type f -name '*.test.ts' ! -name '*.integration.test.ts' ! -path '*/ws.test.ts' ! -path '*/newProduct.test.ts' ! -path '*/external.test.ts' | sort)",
		"test:unit:watch": "bun test --watch $(find contextvm src -type f -name '*.test.ts' ! -name '*.integration.test.ts' ! -path '*/ws.test.ts' ! -path '*/newProduct.test.ts' ! -path '*/external.test.ts' | sort)",
		"test:integration": "bun test $(find src/lib/__tests__ -type f -name '*.integration.test.ts' | sort)"
	},
	"dependencies": {
		"@cashu/cashu-ts": "^2.1",
		"@contextvm/sdk": "^0.8.0",
		"@formkit/auto-animate": "^0.9.0",
		"@getalby/lightning-tools": "^8.1.1",
		"@icons-pack/react-simple-icons": "^13.13.0",
		"@modelcontextprotocol/sdk": "^1.29.0",
		"@noble/hashes": "^2.2.0",
		"@nostr-dev-kit/blossom": "^8.0.0",
		"@nostr-dev-kit/ndk": "3.0.3",
		"@nostr-dev-kit/wallet": "1.0.0",
		"@nostr-dev-kit/wot": "^1.0.0",
		"@radix-ui/react-alert-dialog": "^1.1.15",
		"@radix-ui/react-avatar": "^1.1.11",
		"@radix-ui/react-dialog": "^1.1.15",
		"@scure/base": "^2.2.0",
		"@scure/bip32": "^2.2.0",
		"@tanstack/react-form": "^1.32.0",
		"@tanstack/react-query": "^5.100.10",
		"@tanstack/react-router": "^1.169.2",
		"@tanstack/react-store": "^0.11.0",
		"@tanstack/react-table": "^8.21.3",
		"@tanstack/store": "^0.11.0",
		"@yudiel/react-qr-scanner": "^2.6.0",
		"bitcoinjs-lib": "^7.0.1",
		"bs58check": "^4.0.0",
		"bun-plugin-tailwind": "^0.1.2",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"coco-cashu-core": "^1.0.0-rc11",
		"coco-cashu-indexeddb": "^1.0.0-rc11",
		"date-fns": "^4.1.0",
		"embla-carousel-react": "^8.6.0",
		"light-bolt11-decoder": "^3.2.0",
		"lucide-react": "^1.14.0",
		"maplibre-gl": "^5.24.0",
		"next-themes": "^0.4.6",
		"nostr-tools": "^2.23.3",
		"qrcode.react": "^4.2.0",
		"radix-ui": "^1.4.3",
		"react": "^19.2.6",
		"react-dom": "^19.2.6",
		"react-use": "^17.6.0",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.6.0",
		"uuid": "^14.0.0",
		"vaul": "^1.1.2",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@faker-js/faker": "^10.4.0",
		"@playwright/test": "^1.60.0",
		"@tanstack/react-router-devtools": "^1.166.13",
		"@tanstack/router-cli": "^1.166.43",
		"@tanstack/router-plugin": "^1.167.35",
		"@types/bun": "^1.3.14",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@types/ws": "^8.18.1",
		"mini-svg-data-uri": "^1.4.4",
		"playwright": "^1.60.0",
		"prettier": "^3.8.3",
		"svgo": "^4.0.1",
		"tailwindcss": "^4.3.0",
		"tailwindcss-animate": "^1.0.7",
		"ws": "^8.20.1"
	}
}
