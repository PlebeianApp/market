# Copy this file to .env.local for local happy-path development.
NODE_ENV=development
APP_RELAY_URL=ws://localhost:10547
LOCAL_RELAY_ONLY=true
APP_PRIVATE_KEY=<generate with: nak key generate>
CVM_SERVER_KEY=<generate with: nak key generate>

# CVM server identity (used for live activity signing + verification)
# Tier 1: service-specific (optional, overrides general)
# CVM_CURRENCY_SERVER_PUBLIC_KEY=
# Tier 2: general CVM server pubkey
# CVM_SERVER_PUBLIC_KEY=
# Tier 3: derive from private key (recommended for dev)
CVM_SERVER_KEY=<generate with: nak key generate>
CVM_SERVER_PUBKEY=<derive with: nak key public "$CVM_SERVER_KEY">
