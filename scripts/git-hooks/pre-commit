#!/bin/bash
#
# Pre-commit hook to detect potential private keys and secrets.
#
# Install: cp scripts/git-hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
#   Or:     ln -s ../../scripts/git-hooks/pre-commit .git/hooks/pre-commit

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

FOUND_SECRETS=0

for file in $STAGED_FILES; do
    if [ ! -f "$file" ]; then
        continue
    fi

    case "$file" in
        package-lock.json|bun.lock|*.svg|*.png|*.jpg|*.ico|*.woff2)
            continue
            ;;
    esac

    MATCHES=$(git show ":$file" 2>/dev/null | grep -nE '[0-9a-fA-F]{64}' | grep -vE '^\s*#|\.example|pubkey|pub_key|public.?key|sha256|sha512|hash|commit|^[0-9]+:(\s*\*?\s*(//|/\*|\*))' || true)

    if [ -n "$MATCHES" ]; then
        echo ""
        echo "WARNING: Potential secret/private key detected in $file:"
        echo "$MATCHES" | head -5
        if [ "$(echo "$MATCHES" | wc -l)" -gt 5 ]; then
            echo "  ... ($(echo "$MATCHES" | wc -l) total matches)"
        fi
        FOUND_SECRETS=1
    fi
done

if [ $FOUND_SECRETS -ne 0 ]; then
    echo ""
    echo "Possible private keys or secrets detected in staged files."
    echo "If these are false positives, commit with: git commit --no-verify"
    echo ""
    exit 1
fi

exit 0
