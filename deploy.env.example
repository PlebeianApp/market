# =============================================================================
# deploy.env — Deployment secrets (swap this file per operator)
# Copy to deploy.env and fill in your values:
#   cp deploy.env.example deploy.env
# =============================================================================

# --- REQUIRED: make deploy-local ---
# Local paths for localhost deployment
LOCAL_APP_DIR=/home/c03rad0r/market
LOCAL_APP_USER=c03rad0r

# --- REQUIRED: make deploy (remote VPS via SSH) ---
# Your VPS public IP address
VPS_IP=23.182.128.64

# Path to the SSH private key for VPS access
SSH_KEY_PATH=~/.ssh/id_rsa

# SSH user on the VPS
ANSIBLE_USER=root

# App directory on the VPS (must already have the repo cloned)
VPS_APP_DIR=/root/market

# App user on the VPS (runs the bun processes)
VPS_APP_USER=root

# --- REQUIRED: make deploy-domain (HTTPS/custom domain + Cloudflare) ---
# Your custom domain (the marketplace will be at this domain)
MARKET_DOMAIN=market.yourdomain.com

# Cloudflare API credentials for DNS-01 ACME challenge
CF_API_EMAIL=your-cloudflare-email@example.com
CF_DNS_API_TOKEN=your-cloudflare-api-token-here

# Email for Let's Encrypt certificate notifications
ACME_EMAIL=admin@yourdomain.com
